#
# 패턴과 노이즈에 따른 개수를 세기 위한 data frame#
patterns = unique(Scores$ground_truth)#
length(patterns)#
t2 = Scores %>%#
      group_by(ground_truth,noise_pct) %>%#
      summarise(len = n(), .groups = "keep")#
t2 %>% filter(ground_truth == "spotup_R")#
#
# acc, score 가 일치하는 경우의 acc를 계산하기 위한 data frame#
#
t1 = Scores %>%#
  group_by(ground_truth, label, noise_pct) %>%#
  filter(ground_truth == label)  %>%#
  summarise(avg = mean(score), hit_num = n(), .groups = "keep")#
####
View(t1)#
tmp <- data.frame(ground_truth = rep("spotup_R",1), label = rep("spotup_R",1), noise_pct = as.character(70), avg = rep(0,1), hit_num = rep(0,1))#
t1 <- rbind(t1, tmp)#
#
tmp2 <- t1[order(t1$ground_truth),]#
View(tmp)#
sort(t1$ground_truth)#
#
#ㅍ임시#
View(final)#
final = cbind(t1, len = t2$len)#
final = cbind(tmp2, len = t2$len)#
dim(tmp2)#
final = final %>%#
  group_by(ground_truth, label, noise_pct, hit_num, len)%>%#
  summarise(acc = hit_num/len*100, .groups = "keep")#
#
l = 180#
final = t1 %>%#
  group_by(ground_truth, label, noise_pct, hit_num)%>%#
  summarise(acc = hit_num/l*100, .groups = "keep")#
t1#
#
FINAL_dt = t1#
FINAL_dt = final#
View(FINAL_dt)#
View(t1)#
write.csv(FINAL_dt,file = "final.csv",  quote = F)#
## patterns acc#
# 이 블락의 코드는 혹시 특정 noise의 값을 하나도 못맞춰서 값이 존재하지 않을 경우 0으로 채워주기 위한 코드#
#
for(i in patterns){#
  tmp = t1%>% filter(ground_truth == i)#
  print(tmp)#
  if(nrow(tmp)< 8){#
    add_r <- 8-nrow(tmp)#
    ground_truth <- rep(i, add_r)#
    label <- rep(i,add_r )#
    noise_pct <- as.character(tail(seq(0,70,10),add_r))#
    acc <- rep(0, add_r)#
    avg <- rep(0, add_r)#
    t <- tibble(ground_truth, label, noise_pct, avg, acc)#
    assign(paste0(i,"_acc"), bind_rows(tmp,t))#
  }#
  else{assign(paste0(i,"_acc"), tmp)}#
}#
