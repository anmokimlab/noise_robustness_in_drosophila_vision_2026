table_func = function(JSONfile, topk_num){#
    label = c()#
    ground_truth = c()#
    score = c()#
    noise_pct = c()#
    pattern_num = c()#
    len <- length(attributes(val_json_df)$name)#
    topk = 8#
  for (i in seq(1, len, topk*2)) {#
      tmp = strsplit(str_sub(attributes(val_json_df)$name[i],9,-7) ,split = "_")#
      if ( sum(tmp[[1]] %in% "noise"| tmp[[1]] %in% "noisev2") >= 1){#
        ground_truth = c(ground_truth, paste(tmp[[1]][1],tmp[[1]][2], sep = "_")) # ground truth#
        noise_pct = c(noise_pct, gsub('\\D','', str_sub(attributes(val_json_df)$name[i],-9,-1)))#
        label = c(label, val_json_df[attributes(val_json_df)$name[[i]]][[1]]) #predicted_label#
        score = c(score, val_json_df[attributes(val_json_df)$name[i+1]][[1]]) #predicted_score#
      }else if(sum(tmp[[1]] %in% "noise") == 0){#
        ground_truth = c(ground_truth, paste(tmp[[1]][1],tmp[[1]][2], sep = "_")) # ground truth#
        noise_pct = c(noise_pct, "0")#
        label = c(label, val_json_df[attributes(val_json_df)$name[[i]]][[1]]) #predicted_label#
        score = c(score, val_json_df[attributes(val_json_df)$name[i+1]][[1]]) #predicted_score#
      }#
    }#
    Scores <- data.frame(ground_truth, noise_pct, label, score)#
    return(Scores)#
}#
