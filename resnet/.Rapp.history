dim(tmp2)#
final = final %>%#
  group_by(ground_truth, label, noise_pct, hit_num, len)%>%#
  summarise(acc = hit_num/len*100, .groups = "keep")#
#
l = 180#
final = t1 %>%#
  group_by(ground_truth, label, noise_pct, hit_num)%>%#
  summarise(acc = hit_num/l*100, .groups = "keep")#
